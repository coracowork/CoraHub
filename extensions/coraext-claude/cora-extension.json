{
  "$schema": "https://raw.githubusercontent.com/coracowork/CoraHub/spec/v0/extension-manifest.schema.json",
  "author": "CoraCowork Official",
  "contributes": {
    "acpAdapters": [
      {
        "id": "claude",
        "name": "Claude Code",
        "icon": "resources/icon.svg",
        "description": "Official Claude Code adapter (via ACP adapter)",
        "cliCommand": "claude",
        "defaultCliPath": "bunx @agentclientprotocol/claude-agent-acp",
        "acpArgs": [],
        "skillsDirs": [".claude/skills"]
      }
    ]
  },
  "description": "Integrates Anthropic's Claude Code CLI as an ACP adapter in CoraCowork.",
  "displayName": "Claude Code",
  "engine": {
    "coracowork": "^1.0.0"
  },
  "lifecycle": {
    "onInstall": {
      "shell": {
        "cliCommand": "bun",
        "args": ["run", "scripts/install.ts"]
      },
      "timeout": 120000
    }
  },
  "name": "coraext-claude",
  "version": "1.0.0"
}
